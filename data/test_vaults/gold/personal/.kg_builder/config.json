{
    "link_template": "- {relation_type}:: [[{target_file_name}]]",
    "llm_link_types": [
        "Mentions",
        "Scheduled on",
        "Discusses",
        "Uses",
        "Part of",
        "Watch",
        "Requires"
    ],
    "lang": "ru",
    "link_header": "\n\n## Related Connections\n\n",
    "chunking": {
        "chunk_size": 3000,
        "chunk_overlap": 300,
        "separators": [
            "\n# ",
            "\n## ",
            "\n### ",
            "\n\n",
            ". ",
            "? ",
            "! ",
            "\n",
            " ",
            ""
        ],
        "splitter_type": "recursive",
        "sentence_window_before": 1,
        "sentence_window_after": 1
    },
    "retrieval": {
        "initial_retrieval_k": 15,
        "vector_search_weight": 1.0,
        "broad_query_mode": "chunk"
    },
    "models": {
        "embedding": {
            "model_name": "BAAI/bge-m3"
        },
        "reranker": {
            "model_name": "jinaai/jina-reranker-v2-base-multilingual",
            "top_k": 5,
            "threshold": 0.5
        },
        "llm": {
            "use_api": true,
            "model_path": ".",
            "backend": "vulkan",
            "temperature": 0.0,
            "top_p": 0.1,
            "n_gpu_layers": -1,
            "n_ctx": 8192,
            "n_batch": 512,
            "concurrency": 1
        }
    }
}